package main

// Semantic Example: Dynamic Arrays (runnable subset)

io :: import "std/io"

main :: proc() {
    // Use a fixed-size array as a runnable stand-in.
    numbers: [3]i32 = [10, 20, 30]

    io.println("Length: %d", numbers.len)

    sum: i32 = 0
    for n in numbers {
        sum = sum + n
    }
    io.println("Sum of elements: %d", sum)
    io.println("Second element is: %d", numbers[1])
}
