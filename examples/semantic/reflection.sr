package main

// Semantic Example: Compile-Time Reflection (runnable subset)

io :: import "std/io"
meta :: import "std/meta"

User :: struct {
    id: u64,
    name: string,
    is_active: bool,
}

main :: proc() {
    // Compile-time reflection with std/meta
    comptime {
        _ = meta.typeInfo(User)
    }

    u := User{ id: 123, name: "Alice", is_active: true }
    io.println("User: id=%d name=%s active=%d", (u.id, u.name, u.is_active))
}
