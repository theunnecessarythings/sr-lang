package main

// A small "success" test exercising a handful of features.

io :: import "std/io"

add :: fn(a: i32, b: i32) i32 { return a + b }

main :: proc() {
    x := add(2, 3)
    io.println("x=%d", x)

    // tuple and array
    t := (1, 2)
    arr: [3]i32 = [1, 2, 3]
    io.println("t0=%d arr1=%d", (t.0, arr[1]))

    // optional
    opt: ?i32 = 7
    io.println("opt=%d", opt?)
}
