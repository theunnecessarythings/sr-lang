package math_lib

// Local module used by 14_modules/main.sr.
// Note: module members are currently exported by default; `pub` visibility is planned.

Vector :: struct { x: f64, y: f64 }

add :: proc(a: Vector, b: Vector) Vector {
    return Vector{ x: a.x + b.x, y: a.y + b.y }
}

scale :: proc(v: Vector, s: f64) Vector {
    return Vector{ x: v.x * s, y: v.y * s }
}
