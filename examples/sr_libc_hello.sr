package main

libc_sys :: import "libc/include/syscall"
libc_call :: import "libc/src/syscall/syscall"
libc_exit :: import "libc/src/exit/_Exit"

main :: fn(argc: i32, argv: **u8, envp: **u8) i32 {
    _ = argc
    _ = argv
    _ = envp
    msg := "hello from sr-libc\n"
    _ = libc_call.syscall3_ptr(libc_sys.SYS_write.(i64), 1, msg.ptr, msg.len)
    return 0
}
