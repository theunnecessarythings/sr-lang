package main

// Variable and Constant Declarations (runnable subset)

io :: import "std/io"

PI :: 3.14159
x: i32 = 10
y := 20

Pair :: struct { i: i32, d: f64 }

main :: proc() {
    (a, b): (i32, f64) = (1, 2.0)
    Pair{ i: ai, d: bd }: Pair = Pair{ i: 3, d: 4.5 }

    io.println("PI=%f", PI)
    io.println("x=%d", x)
    io.println("y=%d", y)
    io.println("a=%d b=%f", (a, b))
    io.println("ai=%d bd=%f", (ai, bd))
}
