package main

// Type Examples (runnable subset)

io :: import "std/io"

// Type aliases
array_type :: [10]f64
slice_type :: []u8
tuple_type :: (i32, f64, char)
simd_vec :: simd(f32, 4)
tensor_mat :: tensor(2, 3, i32)
complex_f32 :: complex(f32)
map_type :: [string: i32]

main :: proc() {
    x: i32 = 1
    const_ptr: *const i32 = &x
    mut_ptr: *i32 = &x

    _ = const_ptr
    _ = mut_ptr

    io.println("types demo ok", 0)
}
