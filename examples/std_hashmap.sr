package main

// Example: map-like behavior (runnable subset)

io :: import "std/io"

main :: proc() {
    keys: [2]string = ["key", "other"]
    values: [2]i64 = [123, 456]

    io.println("key=%d", values[0])

    // Simulate removal by ignoring the entry.
    removed := true
    if removed {
        io.println("key missing", 0)
    }
}
