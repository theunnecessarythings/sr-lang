cfgetospeed :: proc(tio: *const struct termios) speed_t
cfgetispeed :: proc(tio: *const struct termios) speed_t
cfsetospeed :: proc(tio: *struct termios, speed: speed_t) i32
cfsetispeed :: proc(tio: *struct termios, speed: speed_t) i32
cfsetspeed :: proc(tio: *struct termios, speed: speed_t) i32

tcgetattr :: proc(fd: i32, tio: *struct termios) i32
tcsetattr :: proc(fd: i32, act: i32, tio: *const struct termios) i32

tcgetwinsize :: proc(fd: i32, wsz: *winsize) i32
tcsetwinsize :: proc(fd: i32, wsz: *const winsize) i32

tcsendbreak :: proc(fd: i32, dur: i32) i32
