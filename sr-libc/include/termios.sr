package libc

// Derived from musl-1.2.5/include/termios.h and arch/generic/bits/termios.h

cc_t :: u8
speed_t :: u32
tcflag_t :: u32

NCCS :: 32

struct termios {
    c_iflag: tcflag_t,
    c_oflag: tcflag_t,
    c_cflag: tcflag_t,
    c_lflag: tcflag_t,
    c_line: cc_t,
    c_cc: [NCCS]cc_t,
    __c_ispeed: speed_t,
    __c_ospeed: speed_t,
}

VINTR :: 0
VQUIT :: 1
VERASE :: 2
VKILL :: 3
VEOF :: 4
