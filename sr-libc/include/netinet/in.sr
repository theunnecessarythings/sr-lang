IN_CLASSA_NET :: 0xff000000
IN_CLASSA_NSHIFT :: 24
IN_CLASSA_HOST :: (0xffffffff & (0xffffffff ^ IN_CLASSA_NET))
IN_CLASSA_MAX :: 128
IN_CLASSB :: proc(a: in_addr_t) i32 { return if (a & 0xc0000000) == 0x80000000 { 1 } else { 0 } }
IN_CLASSB_NET :: 0xffff0000
