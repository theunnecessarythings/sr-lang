IN6_BYTE :: proc(a: *const in6_addr, i: usize) u8 {
    p := a.^*const u8
    return p[i]
}

IN6_IS_ADDR_UNSPECIFIED :: proc(a: *const in6_addr) i32 {
    if IN6_BYTE(a, 0) != 0 { return 0 }
    if IN6_BYTE(a, 1) != 0 { return 0 }
    if IN6_BYTE(a, 2) != 0 { return 0 }
    if IN6_BYTE(a, 3) != 0 { return 0 }
    if IN6_BYTE(a, 4) != 0 { return 0 }
    if IN6_BYTE(a, 5) != 0 { return 0 }
    if IN6_BYTE(a, 6) != 0 { return 0 }
    if IN6_BYTE(a, 7) != 0 { return 0 }
    if IN6_BYTE(a, 8) != 0 { return 0 }
    if IN6_BYTE(a, 9) != 0 { return 0 }
    if IN6_BYTE(a, 10) != 0 { return 0 }
    if IN6_BYTE(a, 11) != 0 { return 0 }
    if IN6_BYTE(a, 12) != 0 { return 0 }
    if IN6_BYTE(a, 13) != 0 { return 0 }
    if IN6_BYTE(a, 14) != 0 { return 0 }
    if IN6_BYTE(a, 15) != 0 { return 0 }
    return 1
}

IN6_IS_ADDR_LOOPBACK :: proc(a: *const in6_addr) i32 {
    if IN6_BYTE(a, 0) != 0 { return 0 }
    if IN6_BYTE(a, 1) != 0 { return 0 }
    if IN6_BYTE(a, 2) != 0 { return 0 }
    if IN6_BYTE(a, 3) != 0 { return 0 }
    if IN6_BYTE(a, 4) != 0 { return 0 }
    if IN6_BYTE(a, 5) != 0 { return 0 }
    if IN6_BYTE(a, 6) != 0 { return 0 }
    if IN6_BYTE(a, 7) != 0 { return 0 }
    if IN6_BYTE(a, 8) != 0 { return 0 }
    if IN6_BYTE(a, 9) != 0 { return 0 }
    if IN6_BYTE(a, 10) != 0 { return 0 }
    if IN6_BYTE(a, 11) != 0 { return 0 }
    if IN6_BYTE(a, 12) != 0 { return 0 }
    if IN6_BYTE(a, 13) != 0 { return 0 }
    if IN6_BYTE(a, 14) != 0 { return 0 }
    if IN6_BYTE(a, 15) != 1 { return 0 }
    return 1
}

IN6_IS_ADDR_MULTICAST :: proc(a: *const in6_addr) i32 {
    return if IN6_BYTE(a, 0) == 0xff { 1 } else { 0 }
}

IN6_IS_ADDR_LINKLOCAL :: proc(a: *const in6_addr) i32 {
    if IN6_BYTE(a, 0) != 0xfe { return 0 }
    if (IN6_BYTE(a, 1) & 0xc0) != 0x80 { return 0 }
    return 1
}

IN6_IS_ADDR_SITELOCAL :: proc(a: *const in6_addr) i32 {
    if IN6_BYTE(a, 0) != 0xfe { return 0 }
    if (IN6_BYTE(a, 1) & 0xc0) != 0xc0 { return 0 }
    return 1
}

IN6_IS_ADDR_V4MAPPED :: proc(a: *const in6_addr) i32 {
    if IN6_BYTE(a, 0) != 0 { return 0 }
    if IN6_BYTE(a, 1) != 0 { return 0 }
    if IN6_BYTE(a, 2) != 0 { return 0 }
    if IN6_BYTE(a, 3) != 0 { return 0 }
    if IN6_BYTE(a, 4) != 0 { return 0 }
    if IN6_BYTE(a, 5) != 0 { return 0 }
    if IN6_BYTE(a, 6) != 0 { return 0 }
    if IN6_BYTE(a, 7) != 0 { return 0 }
    if IN6_BYTE(a, 8) != 0 { return 0 }
    if IN6_BYTE(a, 9) != 0 { return 0 }
    if IN6_BYTE(a, 10) != 0xff { return 0 }
    if IN6_BYTE(a, 11) != 0xff { return 0 }
    return 1
}

IN6_IS_ADDR_V4COMPAT :: proc(a: *const in6_addr) i32 {
    if IN6_BYTE(a, 0) != 0 { return 0 }
    if IN6_BYTE(a, 1) != 0 { return 0 }
    if IN6_BYTE(a, 2) != 0 { return 0 }
    if IN6_BYTE(a, 3) != 0 { return 0 }
    if IN6_BYTE(a, 4) != 0 { return 0 }
    if IN6_BYTE(a, 5) != 0 { return 0 }
    if IN6_BYTE(a, 6) != 0 { return 0 }
    if IN6_BYTE(a, 7) != 0 { return 0 }
    if IN6_BYTE(a, 8) != 0 { return 0 }
    if IN6_BYTE(a, 9) != 0 { return 0 }
    if IN6_BYTE(a, 10) != 0 { return 0 }
    if IN6_BYTE(a, 11) != 0 { return 0 }
    if IN6_BYTE(a, 12) != 0 { return 0 }
    if IN6_BYTE(a, 13) != 0 { return 0 }
    if IN6_BYTE(a, 14) != 0 { return 0 }
    if IN6_BYTE(a, 15) <= 1 { return 0 }
    return 1
}

IN6_IS_ADDR_MC_NODELOCAL :: proc(a: *const in6_addr) i32 {
    if IN6_IS_ADDR_MULTICAST(a) == 0 { return 0 }
    if (IN6_BYTE(a, 1) & 0xf) != 0x1 { return 0 }
    return 1
}

IN6_IS_ADDR_MC_LINKLOCAL :: proc(a: *const in6_addr) i32 {
