package libc

// Derived from musl-1.2.5/include/netinet/in.h
alltypes :: import "libc/include/alltypes"

sa_family_t :: alltypes.sa_family_t
sockaddr_storage :: struct {
    ss_family: sa_family_t,
    __ss_padding: [118]u8,
    __ss_align: u64,
}

in_port_t :: u16
in_addr_t :: u32

in_addr :: struct { s_addr: in_addr_t }

sockaddr_in :: struct {
    sin_family: sa_family_t,
    sin_port: in_port_t,
    sin_addr: in_addr,
    sin_zero: [8]u8,
}

in6_addr :: struct {
    s6_addr: [16]u8,
}

s6_addr16 :: proc(a: *in6_addr) *u16 {
    return (&a.s6_addr[0]).^*u16
}

s6_addr32 :: proc(a: *in6_addr) *u32 {
    return (&a.s6_addr[0]).^*u32
}

sockaddr_in6 :: struct {
    sin6_family: sa_family_t,
    sin6_port: in_port_t,
    sin6_flowinfo: u32,
    sin6_addr: in6_addr,
    sin6_scope_id: u32,
}

ipv6_mreq :: struct {
    ipv6mr_multiaddr: in6_addr,
    ipv6mr_interface: u32,
}

