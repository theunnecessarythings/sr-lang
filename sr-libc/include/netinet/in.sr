    if (IN6_BYTE(a, 1) & 0xf) != 0xe { return 0 }
    return 1
}

IN6_ARE_ADDR_EQUAL :: proc(a: *const in6_addr, b: *const in6_addr) i32 {
    if IN6_BYTE(a, 0) != IN6_BYTE(b, 0) { return 0 }
    if IN6_BYTE(a, 1) != IN6_BYTE(b, 1) { return 0 }
    if IN6_BYTE(a, 2) != IN6_BYTE(b, 2) { return 0 }
    if IN6_BYTE(a, 3) != IN6_BYTE(b, 3) { return 0 }
    if IN6_BYTE(a, 4) != IN6_BYTE(b, 4) { return 0 }
    if IN6_BYTE(a, 5) != IN6_BYTE(b, 5) { return 0 }
    if IN6_BYTE(a, 6) != IN6_BYTE(b, 6) { return 0 }
    if IN6_BYTE(a, 7) != IN6_BYTE(b, 7) { return 0 }
    if IN6_BYTE(a, 8) != IN6_BYTE(b, 8) { return 0 }
    if IN6_BYTE(a, 9) != IN6_BYTE(b, 9) { return 0 }
    if IN6_BYTE(a, 10) != IN6_BYTE(b, 10) { return 0 }
    if IN6_BYTE(a, 11) != IN6_BYTE(b, 11) { return 0 }
    if IN6_BYTE(a, 12) != IN6_BYTE(b, 12) { return 0 }
    if IN6_BYTE(a, 13) != IN6_BYTE(b, 13) { return 0 }
    if IN6_BYTE(a, 14) != IN6_BYTE(b, 14) { return 0 }
    if IN6_BYTE(a, 15) != IN6_BYTE(b, 15) { return 0 }
    return 1
}

