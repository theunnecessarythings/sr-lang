IN_CLASSC :: proc(a: in_addr_t) i32 { return if (a & 0xe0000000) == 0xc0000000 { 1 } else { 0 } }
IN_CLASSC_NET :: 0xffffff00
IN_CLASSC_NSHIFT :: 8
IN_CLASSC_HOST :: (0xffffffff & (0xffffffff ^ IN_CLASSC_NET))
IN_CLASSD :: proc(a: in_addr_t) i32 { return if (a & 0xf0000000) == 0xe0000000 { 1 } else { 0 } }
IN_MULTICAST :: proc(a: in_addr_t) i32 { return IN_CLASSD(a) }
IN_EXPERIMENTAL :: proc(a: in_addr_t) i32 { return if (a & 0xe0000000) == 0xe0000000 { 1 } else { 0 } }
