JT_PHYS_PAGES :: JT(8)
JT_AVPHYS_PAGES :: JT(9)
JT_ZERO :: JT(10)
JT_DELAYTIMER_MAX :: JT(11)
JT_MINSIGSTKSZ :: JT(12)
JT_SIGSTKSZ :: JT(13)

AT_MINSIGSTKSZ :: 51

get_value :: fn(name: i32) i32 {
    switch name {
    case _SC_ARG_MAX: return JT_ARG_MAX
    case _SC_CHILD_MAX: return RLIM(res.RLIMIT_NPROC)
    case _SC_CLK_TCK: return 100
    case _SC_NGROUPS_MAX: return 32
    case _SC_OPEN_MAX: return RLIM(res.RLIMIT_NOFILE)
    case _SC_STREAM_MAX: return -1
    case _SC_TZNAME_MAX: return TZNAME_MAX
    case _SC_JOB_CONTROL: return 1
    case _SC_SAVED_IDS: return 1
    case _SC_REALTIME_SIGNALS: return VER
    case _SC_PRIORITY_SCHEDULING: return -1
    case _SC_TIMERS: return VER
    case _SC_ASYNCHRONOUS_IO: return VER
    case _SC_PRIORITIZED_IO: return -1
    case _SC_SYNCHRONIZED_IO: return -1
    case _SC_FSYNC: return VER
    case _SC_MAPPED_FILES: return VER
    case _SC_MEMLOCK: return VER
    case _SC_MEMLOCK_RANGE: return VER
    case _SC_MEMORY_PROTECTION: return VER
    case _SC_MESSAGE_PASSING: return VER
    case _SC_SEMAPHORES: return VER
    case _SC_SHARED_MEMORY_OBJECTS: return VER
    case _SC_AIO_LISTIO_MAX: return -1
    case _SC_AIO_MAX: return -1
    case _SC_AIO_PRIO_DELTA_MAX: return JT_ZERO
    case _SC_DELAYTIMER_MAX: return JT_DELAYTIMER_MAX
    case _SC_MQ_OPEN_MAX: return -1
    case _SC_MQ_PRIO_MAX: return JT_MQ_PRIO_MAX
    case _SC_VERSION: return VER
    case _SC_PAGE_SIZE: return JT_PAGE_SIZE
    case _SC_RTSIG_MAX: return _NSIG - 1 - 31 - 3
    case _SC_SEM_NSEMS_MAX: return SEM_NSEMS_MAX
    case _SC_SEM_VALUE_MAX: return JT_SEM_VALUE_MAX
    case _SC_SIGQUEUE_MAX: return -1
    case _SC_TIMER_MAX: return -1
    case _SC_BC_BASE_MAX: return BC_BASE_MAX
    case _SC_BC_DIM_MAX: return BC_DIM_MAX
    case _SC_BC_SCALE_MAX: return BC_SCALE_MAX
    case _SC_BC_STRING_MAX: return BC_STRING_MAX
    case _SC_COLL_WEIGHTS_MAX: return COLL_WEIGHTS_MAX
    case _SC_EXPR_NEST_MAX: return -1
    case _SC_LINE_MAX: return -1
    case _SC_RE_DUP_MAX: return RE_DUP_MAX
    case _SC_2_VERSION: return VER
    case _SC_2_C_BIND: return VER
    case _SC_2_C_DEV: return -1
    case _SC_2_FORT_DEV: return -1
    case _SC_2_FORT_RUN: return -1
    case _SC_2_SW_DEV: return -1
    case _SC_2_LOCALEDEF: return -1
    case _SC_IOV_MAX: return IOV_MAX
    case _SC_THREADS: return VER
    case _SC_THREAD_SAFE_FUNCTIONS: return VER
    case _SC_GETGR_R_SIZE_MAX: return -1
    case _SC_GETPW_R_SIZE_MAX: return -1
    case _SC_LOGIN_NAME_MAX: return LOGIN_NAME_MAX
    case _SC_TTY_NAME_MAX: return TTY_NAME_MAX
    case _SC_THREAD_DESTRUCTOR_ITERATIONS: return PTHREAD_DESTRUCTOR_ITERATIONS
    case _SC_THREAD_KEYS_MAX: return PTHREAD_KEYS_MAX
    case _SC_THREAD_STACK_MIN: return PTHREAD_STACK_MIN
    case _SC_THREAD_THREADS_MAX: return -1
    case _SC_THREAD_ATTR_STACKADDR: return VER
    case _SC_THREAD_ATTR_STACKSIZE: return VER
    case _SC_THREAD_PRIORITY_SCHEDULING: return VER
    case _SC_THREAD_PRIO_INHERIT: return -1
    case _SC_THREAD_PRIO_PROTECT: return -1
    case _SC_THREAD_PROCESS_SHARED: return VER
    case _SC_NPROCESSORS_CONF: return JT_NPROCESSORS_CONF
    case _SC_NPROCESSORS_ONLN: return JT_NPROCESSORS_ONLN
    case _SC_PHYS_PAGES: return JT_PHYS_PAGES
    case _SC_AVPHYS_PAGES: return JT_AVPHYS_PAGES
    case _SC_ATEXIT_MAX: return -1
    case _SC_PASS_MAX: return -1
    case _SC_XOPEN_VERSION: return _XOPEN_VERSION
    case _SC_XOPEN_XCU_VERSION: return _XOPEN_VERSION
    case _SC_XOPEN_UNIX: return 1
    case _SC_XOPEN_CRYPT: return -1
    case _SC_XOPEN_ENH_I18N: return 1
    case _SC_XOPEN_SHM: return 1
    case _SC_2_CHAR_TERM: return -1
    case _SC_2_UPE: return -1
    case _SC_XOPEN_XPG2: return -1
    case _SC_XOPEN_XPG3: return -1
    case _SC_XOPEN_XPG4: return -1
    case _SC_NZERO: return NZERO
    case _SC_XBS5_ILP32_OFF32: return -1
    case _SC_XBS5_ILP32_OFFBIG: return -1
    case _SC_XBS5_LP64_OFF64: return 1
    case _SC_XBS5_LPBIG_OFFBIG: return -1
    case _SC_XOPEN_LEGACY: return -1
    case _SC_XOPEN_REALTIME: return -1
    case _SC_XOPEN_REALTIME_THREADS: return -1
    case _SC_ADVISORY_INFO: return VER
    case _SC_BARRIERS: return VER
    case _SC_CLOCK_SELECTION: return VER
    case _SC_CPUTIME: return VER
    case _SC_THREAD_CPUTIME: return VER
    case _SC_MONOTONIC_CLOCK: return VER
    case _SC_READER_WRITER_LOCKS: return VER
    case _SC_SPIN_LOCKS: return VER
    case _SC_REGEXP: return 1
    case _SC_SHELL: return 1
    case _SC_SPAWN: return VER
    case _SC_SPORADIC_SERVER: return -1
    case _SC_THREAD_SPORADIC_SERVER: return -1
    case _SC_TIMEOUTS: return VER
    case _SC_TYPED_MEMORY_OBJECTS: return -1
    case _SC_2_PBS: return -1
    case _SC_2_PBS_ACCOUNTING: return -1
    case _SC_2_PBS_LOCATE: return -1
    case _SC_2_PBS_MESSAGE: return -1
    case _SC_2_PBS_TRACK: return -1
    case _SC_SYMLOOP_MAX: return SYMLOOP_MAX
    case _SC_STREAMS: return JT_ZERO
    case _SC_2_PBS_CHECKPOINT: return -1
    case _SC_V6_ILP32_OFF32: return -1
    case _SC_V6_ILP32_OFFBIG: return -1
    case _SC_V6_LP64_OFF64: return 1
    case _SC_V6_LPBIG_OFFBIG: return -1
    case _SC_HOST_NAME_MAX: return HOST_NAME_MAX
    case _SC_TRACE: return -1
    case _SC_TRACE_EVENT_FILTER: return -1
    case _SC_TRACE_INHERIT: return -1
    case _SC_TRACE_LOG: return -1
    case _SC_IPV6: return VER
    case _SC_RAW_SOCKETS: return VER
    case _SC_V7_ILP32_OFF32: return -1
    case _SC_V7_ILP32_OFFBIG: return -1
    case _SC_V7_LP64_OFF64: return 1
    case _SC_V7_LPBIG_OFFBIG: return -1
    case _SC_SS_REPL_MAX: return -1
    case _SC_TRACE_EVENT_NAME_MAX: return -1
    case _SC_TRACE_NAME_MAX: return -1
    case _SC_TRACE_SYS_MAX: return -1
    case _SC_TRACE_USER_EVENT_MAX: return -1
    case _SC_XOPEN_STREAMS: return JT_ZERO
    case _SC_THREAD_ROBUST_PRIO_INHERIT: return -1
    case _SC_THREAD_ROBUST_PRIO_PROTECT: return -1
    case _SC_MINSIGSTKSZ: return JT_MINSIGSTKSZ
    case _SC_SIGSTKSZ: return JT_SIGSTKSZ
    else: return 0
    }
}

sysconf :: proc(name: i32) i64 {
    v := get_value(name)
    if v == 0 {
        errno_h.errno().* = errno_h.EINVAL
        return -1
    }
    if v >= -1 { return v.(i64) }

    if v < -256 {
        lim: res.rlimit
        _ = res.getrlimit(v & 16383, &lim)
        if lim.rlim_cur == res.RLIM_INFINITY { return -1 }
        if lim.rlim_cur > LONG_MAX.(u64) { return LONG_MAX }
        return lim.rlim_cur.(i64)
    }

    switch (v & 0xff) {
    case VER & 255: return _POSIX_VERSION
    case JT_ARG_MAX & 255: return ARG_MAX
    case JT_MQ_PRIO_MAX & 255: return MQ_PRIO_MAX
    case JT_PAGE_SIZE & 255: return PAGE_SIZE
    case JT_SEM_VALUE_MAX & 255: return SEM_VALUE_MAX
    case JT_DELAYTIMER_MAX & 255: return DELAYTIMER_MAX
    case JT_NPROCESSORS_CONF & 255:
    case JT_NPROCESSORS_ONLN & 255: {
        set: [128]u8
        set[0] = 1
        _ = sc.syscall3(nums.SYS_sched_getaffinity.(i64), 0, set.len.(i64), (&set[0]).^usize.(i64))
        i: i32 = 0
        cnt: i32 = 0
        while i < set.len {
            b := set[i.(usize)]
            while b != 0 {
                b &= b - 1
                cnt += 1
            }
            i += 1
        }
        return cnt
    }
    case JT_PHYS_PAGES & 255:
    case JT_AVPHYS_PAGES & 255: {
        si: info_h.sysinfo
        _ = lsysinfo.__lsysinfo(&si)
        if si.mem_unit == 0 { si.mem_unit = 1 }
        mem: u64
        if name == _SC_PHYS_PAGES {
            mem = si.totalram
        } else {
            mem = si.freeram + si.bufferram
        }
        mem = mem * si.mem_unit
        mem = mem / PAGE_SIZE
        if mem > LONG_MAX.(u64) { return LONG_MAX }
        return mem.(i64)
    }
    case JT_MINSIGSTKSZ & 255:
    case JT_SIGSTKSZ & 255: {
        val := aux.__getauxval(AT_MINSIGSTKSZ).(i64)
        if val < MINSIGSTKSZ { val = MINSIGSTKSZ }
        if v == JT_SIGSTKSZ { val += SIGSTKSZ - MINSIGSTKSZ }
        return val
    }
    case JT_ZERO & 255: return 0
    else: return v
    }
}
