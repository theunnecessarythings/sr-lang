JT :: fn(x: i32) i32 { return -256 | x }
RLIM :: fn(x: i32) i32 { return -32768 | x }

VER :: JT(1)
JT_ARG_MAX :: JT(2)
JT_MQ_PRIO_MAX :: JT(3)
JT_PAGE_SIZE :: JT(4)
JT_SEM_VALUE_MAX :: JT(5)
JT_NPROCESSORS_CONF :: JT(6)
