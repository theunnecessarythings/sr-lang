package libc

// Derived from musl-1.2.5/src/string/stpncpy.c (portable loop).

stpncpy :: proc(dest: *u8, src: *const u8, n: usize) *u8 {
    i: usize = 0
    while i < n and src[i] != 0 {
        dest[i] = src[i]
        i += 1
    }
    if i < n {
        dest[i] = 0
        i += 1
        while i < n {
            dest[i] = 0
            i += 1
        }
        return &dest[i - 1]
    }
    return &dest[n]
}
