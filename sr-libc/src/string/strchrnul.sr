package libc

// Derived from musl-1.2.5/src/string/strchrnul.c (portable loop).

strchrnul :: proc(s: *const u8, c: i32) *const u8 {
    ch := c.(u8)
    i: usize = 0
    while s[i] != 0 and s[i] != ch {
        i += 1
    }
    return &s[i]
}

strchrnul_mut :: proc(s: *u8, c: i32) *u8 {
    ch := c.(u8)
    i: usize = 0
    while s[i] != 0 and s[i] != ch {
        i += 1
    }
    return &s[i]
}
