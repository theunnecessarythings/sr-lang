package libc

// Derived from musl-1.2.5/src/string/strncmp.c (portable loop).

strncmp :: proc(lhs: *const u8, rhs: *const u8, n: usize) i32 {
    i: usize = 0
    while i < n and lhs[i] != 0 and rhs[i] != 0 {
        if lhs[i] != rhs[i] {
            return lhs[i].(i32) - rhs[i].(i32)
        }
        i += 1
    }
    if i == n { return 0 }
    return lhs[i].(i32) - rhs[i].(i32)
}
