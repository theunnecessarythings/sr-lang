package libc

// Derived from musl-1.2.5/src/linux/memfd_create.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

memfd_create :: proc(name: *const u8, flags: u32) i32 {
    r := sc.syscall2_ret(nums.SYS_memfd_create.(i64), name.^usize.(i64), flags.(i64))
    return r.(i32)
}
