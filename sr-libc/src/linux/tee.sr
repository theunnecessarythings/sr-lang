package libc

// Derived from musl-1.2.5/src/linux/tee.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

tee :: proc(src: i32, dest: i32, len: usize, flags: u32) isize {
    r := sc.syscall4_ret(nums.SYS_tee.(i64), src.(i64), dest.(i64), len.(i64), flags.(i64))
    return r.(isize)
}
