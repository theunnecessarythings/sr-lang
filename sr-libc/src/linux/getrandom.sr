package libc

// Derived from musl-1.2.5/src/linux/getrandom.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

getrandom :: proc(buf: *void, buflen: usize, flags: u32) isize {
    r := sc.syscall3_ret(
        nums.SYS_getrandom.(i64),
        buf.^usize.(i64),
        buflen.(i64),
        flags.(i64),
    )
    return r.(isize)
}
