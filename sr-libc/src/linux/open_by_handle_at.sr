package libc

// Derived from musl-1.2.5/src/linux/open_by_handle_at.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

open_by_handle_at :: proc(mount_fd: i32, handle: *file_handle, flags: i32) i32 {
    r := sc.syscall3_ret(nums.SYS_open_by_handle_at.(i64), mount_fd.(i64), handle.^usize.(i64), flags.(i64))
    return r.(i32)
}
