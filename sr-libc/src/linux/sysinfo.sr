package libc

// Derived from musl-1.2.5/src/linux/sysinfo.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"
sysinfo_h :: import "libc/include/sys/sysinfo"

__lsysinfo :: proc(info: *sysinfo_h.sysinfo) i32 {
    r := sc.syscall1_ret(nums.SYS_sysinfo.(i64), info.^usize.(i64))
    return r.(i32)
}

sysinfo :: proc(info: *sysinfo_h.sysinfo) i32 {
    return __lsysinfo(info)
}
