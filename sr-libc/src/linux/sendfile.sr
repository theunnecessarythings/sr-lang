package libc

// Derived from musl-1.2.5/src/linux/sendfile.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

sendfile :: proc(out_fd: i32, in_fd: i32, ofs: ?*alltypes.off_t, count: usize) isize {
    ptr := if ofs == null { 0 } else { ofs.^usize }
    r := sc.syscall4_ret(nums.SYS_sendfile.(i64), out_fd.(i64), in_fd.(i64), ptr.(i64), count.(i64))
    return r.(isize)
}
