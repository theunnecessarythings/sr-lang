package libc

// Derived from musl-1.2.5/src/linux/statx.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

statx :: proc(dirfd: i32, path: *const u8, flags: i32, mask: u32, stx: *statx) i32 {
    r := sc.syscall5_ret(
        nums.SYS_statx.(i64),
        dirfd.(i64),
        path.^usize.(i64),
        flags.(i64),
        mask.(i64),
        stx.^usize.(i64),
    )
    return r.(i32)
}
