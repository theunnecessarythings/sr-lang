package libc

// Derived from musl-1.2.5/src/unistd/lseek.c (x86_64).

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

lseek :: proc(fd: i32, offset: alltypes.off_t, whence: i32) alltypes.off_t {
    r := sc.syscall3_ret(nums.SYS_lseek.(i64), fd.(i64), offset.(i64), whence.(i64))
    return r.(alltypes.off_t)
}
