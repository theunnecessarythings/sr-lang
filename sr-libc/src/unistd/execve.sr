package libc

// Derived from musl-1.2.5/src/process/execve.c (syscall wrapper).

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

execve :: proc(path: *const u8, argv: **u8, envp: **u8) i32 {
    r := sc.syscall3_ret(nums.SYS_execve.(i64), path.^usize.(i64), argv.^usize.(i64), envp.^usize.(i64))
    return r.(i32)
}
