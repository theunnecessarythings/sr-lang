package libc

// Derived from musl-1.2.5/src/unistd/write.c (syscall wrapper).

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

write :: proc(fd: i32, buf: *const void, count: usize) isize {
    r := sc.syscall3_ret(nums.SYS_write.(i64), fd.(i64), buf.^usize.(i64), count.(i64))
    return r.(isize)
}
