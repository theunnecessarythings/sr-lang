package libc

// Derived from musl-1.2.5/src/unistd/renameat.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

renameat :: proc(olddirfd: i32, oldpath: *const u8, newdirfd: i32, newpath: *const u8) i32 {
    r := sc.syscall4_ret(nums.SYS_renameat.(i64), olddirfd.(i64), oldpath.^usize.(i64), newdirfd.(i64), newpath.^usize.(i64))
    return r.(i32)
}
