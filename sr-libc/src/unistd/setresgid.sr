package libc

// Derived from musl-1.2.5/src/unistd/setresgid.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

setresgid :: proc(rgid: gid_t, egid: gid_t, sgid: gid_t) i32 {
    r := sc.syscall3_ret(nums.SYS_setresgid.(i64), rgid.(i64), egid.(i64), sgid.(i64))
    return r.(i32)
}
