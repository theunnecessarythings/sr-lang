package libc

// Derived from musl-1.2.5/src/unistd/unlinkat.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

unlinkat :: proc(dirfd: i32, path: *const u8, flags: i32) i32 {
    r := sc.syscall3_ret(nums.SYS_unlinkat.(i64), dirfd.(i64), path.^usize.(i64), flags.(i64))
    return r.(i32)
}
