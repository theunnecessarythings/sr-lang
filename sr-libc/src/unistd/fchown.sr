package libc

// Derived from musl-1.2.5/src/unistd/fchown.c (syscall wrapper).

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

fchown :: proc(fd: i32, uid: uid_t, gid: gid_t) i32 {
    r := sc.syscall3_ret(nums.SYS_fchown.(i64), fd.(i64), uid.(i64), gid.(i64))
    return r.(i32)
}
