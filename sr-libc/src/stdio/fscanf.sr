package libc

// Derived from musl-1.2.5/src/stdio/fscanf.c.

stdarg_mod :: import "libc/include/stdarg"

fscanf :: proc(f: *alltypes.FILE, fmt: *const u8, args: any) i32 {
    ap: stdarg_mod.va_list
    stdarg_mod.va_start(&ap)
    ret := vfscanf(f, fmt, ap)
    stdarg_mod.va_end(&ap)
    return ret
}
