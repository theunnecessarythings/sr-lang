package libc

// Derived from musl-1.2.5/src/process/waitpid.c

syscall :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

waitpid :: proc(pid: i32, status: *i32, options: i32) i32 {
    // Calling SYS_wait4 directly
    return syscall.syscall4_ret(nums.SYS_wait4.(i64), pid.(i64), status.^usize.(i64), options.(i64), 0).(i32)
}
