package libc

// Derived from musl-1.2.5/src/process/waitid.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

waitid :: proc(type: idtype_t, id: id_t, info: *siginfo_t, options: i32) i32 {
    r := sc.syscall5_ret(nums.SYS_waitid.(i64), type.(i64), id.(i64), info.^usize.(i64), options.(i64), 0)
    return r.(i32)
}
