package libc

// Derived from musl-1.2.5/src/thread/pthread_condattr_setpshared.c

errno_mod :: import "libc/include/errno"

pthread_condattr_setpshared :: proc(a: *pthread_condattr_t, pshared: i32) i32 {
    if pshared > 1 { return errno_mod.EINVAL }
    a.__attr &= 0x7fffffff
    a.__attr |= (pshared.(u32) << 31)
    return 0
}
