package libc

// Derived from musl-1.2.5/src/thread/pthread_spin_lock.c

atomic :: import "libc/src/internal/atomic"
errno_mod :: import "libc/include/errno"

pthread_spin_lock :: proc(s: *pthread_spinlock_t) i32 {
    while true {
        if s.* == 0 && atomic.a_cas(s.^*i32, 0, errno_mod.EBUSY) == 0 { break }
        atomic.a_spin()
    }
    return 0
}
