package libc

// Derived from musl-1.2.5/src/thread/pthread_attr_setscope.c

attr_int :: import "libc/src/thread/pthread_attr_internal"
errno_mod :: import "libc/include/errno"

pthread_attr_setscope :: proc(a: *alltypes.pthread_attr_t, scope: i32) i32 {
    _ = a
    switch scope {
        attr_int.PTHREAD_SCOPE_SYSTEM => { return 0 }
        attr_int.PTHREAD_SCOPE_PROCESS => { return errno_mod.ENOTSUP }
        else => { return errno_mod.EINVAL }
    }
}
