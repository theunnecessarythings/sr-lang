package libc

// Derived from musl-1.2.5/src/thread/pthread_mutexattr_settype.c

errno_mod :: import "libc/include/errno"

pthread_mutexattr_settype :: proc(a: *pthread_mutexattr_t, typ: i32) i32 {
    if (typ.(u32) > 2) { return errno_mod.EINVAL }
    a.__attr = (a.__attr & ~3) | typ.(u32)
    return 0
}
