package libc

// Derived from musl-1.2.5/src/thread/pthread_attr_setdetachstate.c

attr_int :: import "libc/src/thread/pthread_attr_internal"
errno_mod :: import "libc/include/errno"

pthread_attr_setdetachstate :: proc(a: *alltypes.pthread_attr_t, state: i32) i32 {
    if state > 1 { return errno_mod.EINVAL }
    attr_int.attr_detach(a).* = state
    return 0
}
