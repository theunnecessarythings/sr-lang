pthread_impl :: import "libc/src/internal/pthread_impl"

__pthread_self_internal :: proc() alltypes.pthread_t {
    return pthread_impl.__pthread_self().(^*void)
}

pthread_self :: proc() alltypes.pthread_t {
    return __pthread_self_internal()
}

thrd_current :: proc() alltypes.pthread_t {
    return __pthread_self_internal()
}
