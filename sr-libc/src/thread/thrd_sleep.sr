package libc

// Derived from musl-1.2.5/src/thread/thrd_sleep.c

time_mod :: import "libc/src/unistd/nanosleep"
errno_mod :: import "libc/include/errno"

thrd_sleep :: proc(req: *const timespec, rem: *timespec) i32 {
    r := time_mod.nanosleep(req, rem)
    if r == 0 { return 0 }
    if errno_mod.__errno_location().* == errno_mod.EINTR { return -1 }
    return -2
}
