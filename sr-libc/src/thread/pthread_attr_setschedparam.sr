package libc

// Derived from musl-1.2.5/src/thread/pthread_attr_setschedparam.c

attr_int :: import "libc/src/thread/pthread_attr_internal"

pthread_attr_setschedparam :: proc(a: *alltypes.pthread_attr_t, param: *const struct sched_param) i32 {
    attr_int.attr_prio(a).* = param.sched_priority
    return 0
}
