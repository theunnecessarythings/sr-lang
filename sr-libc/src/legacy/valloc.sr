package libc

// Derived from musl-1.2.5/src/legacy/valloc.c

getpagesize_mod :: import "libc/src/legacy/getpagesize"
aligned_alloc_mod :: import "libc/src/malloc/mallocng/aligned_alloc"

valloc :: proc(size: usize) *void {
    align := getpagesize_mod.getpagesize().(usize)
    return aligned_alloc_mod.aligned_alloc(align, size)
}
