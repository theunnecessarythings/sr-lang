package libc

// Derived from musl-1.2.5/src/mq/mq_receive.c

mq_h :: import "libc/include/mqueue"
nums :: import "libc/include/syscall"
sc :: import "libc/src/syscall/syscall"

mq_receive :: proc(mqd: mq_h.mqd_t, msg: *u8, len: usize, prio: *u32) isize {
    r := sc.syscall5_ret(
        nums.SYS_mq_timedreceive.(i64),
        mqd.(i64),
        msg.^usize.(i64),
        len.(i64),
        prio.^usize.(i64),
        0,
    )
    return r.(isize)
}
