__ctype_get_mb_cur_max :: proc() usize { return 1 }

isalpha :: proc(c: i32) i32 {
    return ((c | 32) >= 97 and (c | 32) <= 122).(i32)
}

isdigit :: proc(c: i32) i32 {
    return (c >= 48 and c <= 57).(i32)
}

isalnum :: proc(c: i32) i32 { return (isalpha(c) != 0 or isdigit(c) != 0).(i32) }

isascii :: proc(c: i32) i32 { return ((c & (-128).(i32)) == 0).(i32) }

isblank :: proc(c: i32) i32 { return (c == 9 or c == 32).(i32) }

iscntrl :: proc(c: i32) i32 { return (c < 32 or c == 127).(i32) }

isgraph :: proc(c: i32) i32 { return (c > 32 and c < 127).(i32) }

islower :: proc(c: i32) i32 { return (c >= 97 and c <= 122).(i32) }

isprint :: proc(c: i32) i32 { return (c >= 32 and c < 127).(i32) }

ispunct :: proc(c: i32) i32 { return (isgraph(c) != 0 and isalnum(c) == 0).(i32) }

isspace :: proc(c: i32) i32 {
    return (c == 32 or c == 9 or c == 10 or c == 11 or c == 12 or c == 13).(i32)
}

isupper :: proc(c: i32) i32 { return (c >= 65 and c <= 90).(i32) }

isxdigit :: proc(c: i32) i32 {
    return (isdigit(c) != 0 or (c >= 65 and c <= 70) or (c >= 97 and c <= 102)).(i32)
}

toascii :: proc(c: i32) i32 { return c & 0x7f }

tolower :: proc(c: i32) i32 {
    if isupper(c) != 0 { return c | 32 }
    return c
}

toupper :: proc(c: i32) i32 {
    if islower(c) != 0 { return c & (-33).(i32) }
    return c
}

__isalnum_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isalnum(c) }
__isalpha_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isalpha(c) }
__isascii_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isascii(c) }
__isblank_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isblank(c) }
__iscntrl_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return iscntrl(c) }
__isdigit_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isdigit(c) }
__isgraph_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isgraph(c) }
__islower_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return islower(c) }
__isprint_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isprint(c) }
__ispunct_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return ispunct(c) }
__isspace_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isspace(c) }
__isupper_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isupper(c) }
__isxdigit_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return isxdigit(c) }

isalnum_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __isalnum_l(c, l) }
isalpha_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __isalpha_l(c, l) }
isascii_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __isascii_l(c, l) }
