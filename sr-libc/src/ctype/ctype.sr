islower_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __islower_l(c, l) }
isprint_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __isprint_l(c, l) }
ispunct_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __ispunct_l(c, l) }
isspace_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __isspace_l(c, l) }
isupper_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __isupper_l(c, l) }
isxdigit_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __isxdigit_l(c, l) }

__tolower_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return tolower(c) }
__toupper_l :: proc(c: i32, l: alltypes.locale_t) i32 { _ = l; return toupper(c) }

tolower_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __tolower_l(c, l) }
toupper_l :: proc(c: i32, l: alltypes.locale_t) i32 { return __toupper_l(c, l) }
