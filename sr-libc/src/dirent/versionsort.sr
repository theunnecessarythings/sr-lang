package libc

// Derived from musl-1.2.5/src/dirent/versionsort.c

strverscmp_mod :: import "libc/src/string/strverscmp"

versionsort :: proc(a: *const *const dirent, b: *const *const dirent) i32 {
    if a == null || b == null { return 0 }
    lhs := (&a.*.d_name[0]).^*const u8
    rhs := (&b.*.d_name[0]).^*const u8
    return strverscmp_mod.strverscmp(lhs, rhs)
}
