package libc

// Derived from musl-1.2.5/src/termios/tcgetattr.c

// TODO: Convert includes to sr-lang imports
// #include <termios.h>
// #include <sys/ioctl.h>

ioctl_mod :: import "libc/src/misc/ioctl"
ioctl_consts :: import "libc/include/sys/ioctl"

tcgetattr :: proc(fd: i32, tio: *struct termios) i32 {
    if ioctl_mod.ioctl(fd, ioctl_consts.TCGETS, tio.^*void) != 0 { return -1 }
    return 0
}
