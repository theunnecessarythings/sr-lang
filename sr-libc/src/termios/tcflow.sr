package libc

// Derived from musl-1.2.5/src/termios/tcflow.c

// TODO: Convert includes to sr-lang imports
// #include <termios.h>
// #include <sys/ioctl.h>

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"
ioctl_consts :: import "libc/include/sys/ioctl"

tcflow :: proc(fd: i32, action: i32) i32 {
    r := sc.syscall3_ret(nums.SYS_ioctl.(i64), fd.(i64), ioctl_consts.TCXONC.(i64), action.(i64))
    return r.(i32)
}
