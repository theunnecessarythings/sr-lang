package libc

// Derived from musl-1.2.5/src/termios/tcdrain.c

// TODO: Convert includes to sr-lang imports
// #include <termios.h>
// #include <sys/ioctl.h>
// #include <syscall.h>

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"
ioctl_consts :: import "libc/include/sys/ioctl"

tcdrain :: proc(fd: i32) i32 {
    r := sc.syscall3_ret(nums.SYS_ioctl.(i64), fd.(i64), ioctl_consts.TCSBRK.(i64), 1)
    return r.(i32)
}
