package libc

// Derived from musl-1.2.5/src/signal/sigwait.c

sigwaitinfo_mod :: import "libc/src/signal/sigwaitinfo"

sigwait :: proc(mask: *const alltypes.sigset_t, sig: *i32) i32 {
    info: siginfo_t
    r := sigwaitinfo_mod.sigwaitinfo(mask, &info)
    if r < 0 { return r }
    if sig != null { sig.* = info.si_signo }
    return 0
}
