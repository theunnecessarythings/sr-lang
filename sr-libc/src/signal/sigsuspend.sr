package libc

// Derived from musl-1.2.5/src/signal/sigsuspend.c

nums :: import "libc/include/syscall"
sc :: import "libc/src/syscall/syscall"

sigsuspend :: proc(mask: *const alltypes.sigset_t) i32 {
    r := sc.syscall2_ret(
        nums.SYS_rt_sigsuspend.(i64),
        mask.^usize.(i64),
        sizeof(alltypes.sigset_t).(i64),
    )
    return r.(i32)
}
