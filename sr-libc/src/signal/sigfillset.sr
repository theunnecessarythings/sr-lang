package libc

// Derived from musl-1.2.5/src/signal/sigfillset.c

alltypes :: import "libc/include/alltypes"

sigfillset :: proc(set: ?*alltypes.sigset_t) i32 {
    if set == null { return -1 }
    s := set?
    i: usize = 0
    while i < 16 {
        s.__bits[i] = (-1).(u64)
        i += 1
    }
    return 0
}
