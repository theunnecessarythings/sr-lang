F64_MAX :: 1.7976931348623157e308
F128_MAX :: 1.189731495357231765085759326628007e4932

w_isspace :: fn(c: wchar_t) bool {
    if c < 0 or c > 127 { return false }
    return ctype.isspace(c.(i32)) != 0
}

w_is_digit :: fn(c: wchar_t) bool {
    return c >= 48 and c <= 57
}

w_is_hex :: fn(c: wchar_t) bool {
    return (c >= 48 and c <= 57) or (c >= 65 and c <= 70) or (c >= 97 and c <= 102)
}

w_hex_val :: fn(c: wchar_t) i32 {
    if c >= 48 and c <= 57 { return (c - 48).(i32) }
    if c >= 65 and c <= 70 { return (c - 65 + 10).(i32) }
    if c >= 97 and c <= 102 { return (c - 97 + 10).(i32) }
    return -1
}

pow10_f64 :: fn(exp: i32) f64 {
    if exp == 0 { return 1.0 }
    e := exp
    base: f64 = 10.0
    if e < 0 {
        base = 0.1
        e = -e
    }
    result: f64 = 1.0
    while e > 0 {
        if (e & 1) != 0 { result = result * base }
        base = base * base
        e >>= 1
    }
    return result
}

pow2_f64 :: fn(exp: i32) f64 {
    if exp == 0 { return 1.0 }
    e := exp
    base: f64 = 2.0
    if e < 0 {
        base = 0.5
        e = -e
    }
    result: f64 = 1.0
    while e > 0 {
        if (e & 1) != 0 { result = result * base }
        base = base * base
        e >>= 1
    }
    return result
}

