}

wcstod :: proc(s: *const wchar_t, endptr: ?**wchar_t) f64 {
    p := s
    while w_isspace(p[0]) { p = (&p[1]).^*wchar_t }

    if (p[0] | 32) == 110 and (p[1] | 32) == 97 and (p[2] | 32) == 110 {
        if endptr != null { endptr?.* = (&p[3]).^*wchar_t }
        return 0.0 / 0.0
    }
    if (p[0] | 32) == 105 and (p[1] | 32) == 110 and (p[2] | 32) == 102 {
        if (p[3] | 32) == 105 {
            if endptr != null { endptr?.* = (&p[8]).^*wchar_t }
        } else if endptr != null {
            endptr?.* = (&p[3]).^*wchar_t
        }
        return 1.0 / 0.0
    }

    if (p[0] == 43 or p[0] == 45) and p[1] == 48 and (p[2] | 32) == 120 {
        return parse_hex_w_f64(p, endptr)
    }
    if p[0] == 48 and (p[1] | 32) == 120 {
        return parse_hex_w_f64(p, endptr)
    }
    return parse_decimal_w_f64(p, endptr)
}

