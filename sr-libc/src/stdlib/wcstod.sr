parse_decimal_w_f64 :: fn(p_in: *const wchar_t, endptr: ?**wchar_t) f64 {
    p := p_in
    sign: f64 = 1.0
    if p[0] == 45 { sign = -1.0; p = (&p[1]).^*wchar_t }
    else if p[0] == 43 { p = (&p[1]).^*wchar_t }

    any := false
    int_part: f64 = 0.0
    while w_is_digit(p[0]) {
        any = true
        int_part = int_part * 10.0 + (p[0] - 48).(f64)
        p = (&p[1]).^*wchar_t
    }

    frac_part: f64 = 0.0
    if p[0] == 46 {
        p = (&p[1]).^*wchar_t
        div: f64 = 10.0
        while w_is_digit(p[0]) {
            any = true
            frac_part = frac_part + (p[0] - 48).(f64) / div
            div = div * 10.0
            p = (&p[1]).^*wchar_t
        }
    }

    if !any {
        errno_mod.__errno_location().* = errno_mod.EINVAL
        if endptr != null { endptr?.* = p_in }
        return 0.0
    }

    exp: i32 = 0
    if p[0] == 101 or p[0] == 69 {
        p = (&p[1]).^*wchar_t
        neg_exp := false
        if p[0] == 45 { neg_exp = true; p = (&p[1]).^*wchar_t }
        else if p[0] == 43 { p = (&p[1]).^*wchar_t }
        if w_is_digit(p[0]) {
            while w_is_digit(p[0]) {
                exp = exp * 10 + (p[0] - 48).(i32)
                p = (&p[1]).^*wchar_t
            }
            if neg_exp { exp = -exp }
        }
    }

    if endptr != null { endptr?.* = p }

    val := (int_part + frac_part) * pow10_f64(exp)
    if val > F64_MAX {
        errno_mod.__errno_location().* = errno_mod.ERANGE
        return sign * F64_MAX
    }
    if val == 0.0 and (int_part + frac_part) != 0.0 {
        errno_mod.__errno_location().* = errno_mod.ERANGE
    }
    return sign * val
}

