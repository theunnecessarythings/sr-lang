package libc

// Derived from musl-1.2.5/src/misc/setpriority.c

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

setpriority :: proc(which: i32, who: id_t, prio: i32) i32 {
    r := sc.syscall3_ret(nums.SYS_setpriority.(i64), which.(i64), who.(i64), prio.(i64))
    return r.(i32)
}
