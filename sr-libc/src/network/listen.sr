package libc

// Derived from musl-1.2.5/src/network/listen.c

// TODO: Convert includes to sr-lang imports
// #include <sys/socket.h>
// #include <syscall.h>

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

listen :: proc(fd: i32, backlog: i32) i32 {
    r := sc.syscall2_ret(nums.SYS_listen.(i64), fd.(i64), backlog.(i64))
    return r.(i32)
}
