package libc

// Derived from musl-1.2.5/src/stat/chmod.c (syscall wrapper).

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

chmod :: proc(path: *const u8, mode: mode_t) i32 {
    // Prefer SYS_chmod if present; fallback to fchmodat if needed.
    r := sc.syscall2_ret(nums.SYS_chmod.(i64), path.^usize.(i64), mode.(i64))
    return r.(i32)
}
