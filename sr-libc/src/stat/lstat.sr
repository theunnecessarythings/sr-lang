package libc

// Derived from musl-1.2.5/src/stat/lstat.c (syscall wrapper).

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

lstat :: proc(path: *const u8, buf: *stat) i32 {
    r := sc.syscall2_ret(nums.SYS_lstat.(i64), path.^usize.(i64), buf.^usize.(i64))
    return r.(i32)
}
