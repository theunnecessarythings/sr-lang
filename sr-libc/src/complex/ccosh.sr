package libc

// Derived from musl-1.2.5/src/complex/ccosh.c

impl :: import "libc/src/complex/complex_impl"
ldexp_mod :: import "libc/src/complex/__cexp"

huge :: 0x1p1023

ccosh :: proc(z: complex(f64)) complex(f64) {
    x := z.real
    y := z.imag
    hx: u32 = 0
    hy: u32 = 0
    lx: u32 = 0
    ly: u32 = 0

    impl.get_f64_words(x, &hx, &lx)
    impl.get_f64_words(y, &hy, &ly)

    ix := hx & 0x7fffffff
    iy := hy & 0x7fffffff

    if ix < 0x7ff00000 and iy < 0x7ff00000 {
        if (iy | ly) == 0 {
            return impl.cmplx(cosh(x), x * y)
        }
        if ix < 0x40360000 {
            return impl.cmplx(cosh(x) * cos(y), sinh(x) * sin(y))
        }
        if ix < 0x40862e42 {
            h := exp(fabs(x)) * 0.5
            return impl.cmplx(h * cos(y), copysign(h, x) * sin(y))
        }
        if ix < 0x4096bbaa {
            w := ldexp_mod.__ldexp_cexp(impl.cmplx(fabs(x), y), -1)
            return impl.cmplx(w.real, w.imag * copysign(1.0, x))
        }
        h := huge * x
        return impl.cmplx(h * h * cos(y), h * sin(y))
    }

    if (ix | lx) == 0 and iy >= 0x7ff00000 {
        return impl.cmplx(y - y, copysign(0.0, x * (y - y)))
    }

    if (iy | ly) == 0 and ix >= 0x7ff00000 {
        if (((hx & 0xfffff) | lx) == 0) {
            return impl.cmplx(x * x, copysign(0.0, x) * y)
        }
        return impl.cmplx(x * x, copysign(0.0, (x + x) * y))
    }

    if ix < 0x7ff00000 and iy >= 0x7ff00000 {
        return impl.cmplx(y - y, x * (y - y))
    }

    if ix >= 0x7ff00000 and ((hx & 0xfffff) | lx) == 0 {
        if iy >= 0x7ff00000 {
            return impl.cmplx(x * x, x * (y - y))
        }
        return impl.cmplx((x * x) * cos(y), x * sin(y))
    }

    return impl.cmplx((x * x) * (y - y), (x + x) * (y - y))
}
