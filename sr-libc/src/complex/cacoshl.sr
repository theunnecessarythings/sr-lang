package libc

// Derived from musl-1.2.5/src/complex/cacoshl.c

impl :: import "libc/src/complex/complex_impl"

cacoshl :: proc(z: complex(f128)) complex(f128) {
    zineg := signbitl(z.imag) != 0
    z = cacosl(z)
    if zineg {
        return impl.cmplxl(z.imag, -z.real)
    }
    return impl.cmplxl(-z.imag, z.real)
}
