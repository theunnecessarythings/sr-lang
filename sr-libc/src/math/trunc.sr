package libc

// Derived from musl-1.2.5/src/math/trunc.c.

libm :: import "libc/src/math/libm_internal"

trunc :: proc(x: f64) f64 {
    u_bits := libm.asuint64(x)
    e := ((u_bits >> 52) & 0x7ff).(i32) - 0x3ff + 12
    m: u64

    if e >= 52 + 12 { return x }
    if e < 12 { e = 1 }
    m = 0xffff_ffff_ffff_ffff >> e
    if (u_bits & m) == 0 { return x }
    libm.fp_force_eval(x + 0x1p120)
    u_bits = u_bits & ~m
    return libm.asdouble(u_bits)
}
