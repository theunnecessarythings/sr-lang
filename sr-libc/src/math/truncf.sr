package libc

// Derived from musl-1.2.5/src/math/truncf.c.

libm :: import "libc/src/math/libm_internal"

truncf :: proc(x: f32) f32 {
    u_bits := libm.asuint(x)
    e := ((u_bits >> 23) & 0xff).(i32) - 0x7f + 9
    m: u32

    if e >= 23 + 9 { return x }
    if e < 9 { e = 1 }
    m = 0xffff_ffff >> e
    if (u_bits & m) == 0 { return x }
    libm.fp_force_eval(x + 0x1p120f)
    u_bits &= ~m
    return libm.asfloat(u_bits)
}
