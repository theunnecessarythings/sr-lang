rpoly :: fn(w: f128) f128 {
    return T5 + w * (T9 + w * (T13 + w * (T17 + w * (T21 + w * (T25 + w *
        (T29 + w * (T33 + w * (T37 + w * (T41 + w * (T45 + w * (T49 +
        w * (T53 + w * T57))))))))))))
}

