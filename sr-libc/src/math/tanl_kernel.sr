        w * T55))))))))))))
}

__tanl :: proc(x: f128, y: f128, odd: i32) f128 {
    z: f128
    r: f128
    v: f128
    w: f128
    s: f128
    a: f128
    t: f128
    big := basic.fabsl(x) >= 0.67434
    sign := false

    if big {
        if x < 0.0 {
            sign = true
            x = -x
            y = -y
        }
        x = (pio4 - x) + (pio4lo - y)
        y = 0.0
    }

    z = x * x
    w = z * z
    r = rpoly(w)
    v = z * vpoly(w)
    s = z * x
    r = y + z * (s * (r + v) + y) + T3 * s
    w = x + r

    if big {
        s = 1.0 - 2.0 * odd.(f128)
        v = s - 2.0 * (x + (r - w * w / (w + s)))
        return if sign { -v } else { v }
    }

    if odd == 0 { return w }

    z = w
    z = z + 0x1p32 - 0x1p32
    v = r - (z - x)
    t = a = -1.0 / w
    t = t + 0x1p32 - 0x1p32
    s = 1.0 + t * z
    return t + a * (s + t * v)
}
