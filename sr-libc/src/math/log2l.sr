package libc

// Derived from musl-1.2.5/src/math/log2l.c (ld80 coefficients, f128 path).

basic :: import "libc/src/math/basic"

P: [7]f128 = [
    4.9962495940332550844739e-1,
    1.0767376367209449010438e1,
    7.7671073698359539859595e1,
    2.5620629828144409632571e2,
    4.2401812743503691187826e2,
    3.4258224542413922935104e2,
    1.0747524399916215149070e2,
]

Q: [7]f128 = [
    2.3479774160285863271658e1,
    1.9444210022760132894510e2,
    7.7952888181207260646090e2,
    1.6911722418503949084863e3,
    2.0307734695595183428202e3,
    1.2695660352705325274404e3,
