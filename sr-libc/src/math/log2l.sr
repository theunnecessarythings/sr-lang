S: [3]f128 = [
    -2.6201045551331104417768e1,
    1.9361891836232102174846e2,
    -4.2861221385716144629696e2,
]

LOG2EA :: 4.4269504088896340735992e-1
SQRTH :: 0.70710678118654752440

polevll :: fn(x: f128, coef: *f128, n: i32) f128 {
    i: i32 = 1
    ans := coef[0]
    while i <= n {
        ans = ans * x + coef[i.(usize)]
        i += 1
    }
    return ans
}

p1evll :: fn(x: f128, coef: *f128, n: i32) f128 {
    i: i32 = 1
    ans := x + coef[0]
    while i < n {
        ans = ans * x + coef[i.(usize)]
        i += 1
    }
    return ans
}

log2l :: proc(x: f128) f128 {
    if basic.isnanl(x) { return x }
    if x == basic.f128_inf { return x }
    if x <= 0.0 {
        if x == 0.0 { return -1.0 / (x * x) }
        return 0.0 / 0.0
    }

    e: i32
    x = frexpl(x, &e)

    y: f128
    z: f128

    if e > 2 or e < -2 {
        if x < SQRTH {
            e -= 1
            z = x - 0.5
            y = 0.5 * z + 0.5
        } else {
            z = x - 0.5
            z -= 0.5
            y = 0.5 * x + 0.5
        }
        x = z / y
        z = x * x
        y = x * (z * polevll(z, &R[0], 3) / p1evll(z, &S[0], 3))
    } else {
        if x < SQRTH {
            e -= 1
            x = 2.0 * x - 1.0
        } else {
            x = x - 1.0
        }
        z = x * x
        y = x * (z * polevll(x, &P[0], 6) / p1evll(x, &Q[0], 7))
        y = y - 0.5 * z
    }

    z = y * LOG2EA
    z += x * LOG2EA
    z += y
    z += x
    z += e
    return z
}
