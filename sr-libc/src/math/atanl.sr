T_even :: fn(x: f128) f128 {
    return aT[0] + x * (aT[2] + x * (aT[4] + x * (aT[6] + x * (aT[8] +
        x * (aT[10] + x * (aT[12] + x * (aT[14] + x * (aT[16] +
        x * (aT[18] + x * (aT[20] + x * aT[22]))))))))))
}

T_odd :: fn(x: f128) f128 {
