        x * (aT[11] + x * (aT[13] + x * (aT[15] + x * (aT[17] +
        x * (aT[19] + x * (aT[21] + x * aT[23]))))))))))
}

atanl :: proc(x: f128) f128 {
    bits := x.^u128
    exp := ((bits >> 112) & 0x7fff).(u32)
    sign := ((bits >> 127) & 1) != 0
    top := ((bits >> 96) & 0xffff).(u32)
    expman := ((exp & 0x7fff) << 8) | (top >> 8)
    w: f128
    s1: f128
    s2: f128
    z: f128
    id: i32

    if exp >= 0x3fff + 114 {
        if basic.isnanl(x) { return x }
        return if sign { -atanhi[3] } else { atanhi[3] }
    }

    if expman < ((0x3fff - 2) << 8) + 0xc0 {
        if exp < 0x3fff - (113 + 1) / 2 {
            if exp == 0 { libm.fp_force_evalf(x.(f32)) }
            return x
        }
        id = -1
    } else {
        x = basic.fabsl(x)
        if expman < (0x3fff << 8) + 0x30 {
            if expman < ((0x3fff - 1) << 8) + 0x60 {
                id = 0
                x = (2.0 * x - 1.0) / (2.0 + x)
            } else {
                id = 1
                x = (x - 1.0) / (x + 1.0)
            }
        } else {
            if expman < ((0x3fff + 1) << 8) + 0x38 {
                id = 2
                x = (x - 1.5) / (1.0 + 1.5 * x)
            } else {
                id = 3
                x = -1.0 / x
            }
        }
    }

    z = x * x
    w = z * z
    s1 = z * T_even(w)
    s2 = w * T_odd(w)

    if id < 0 { return x - x * (s1 + s2) }
    z = atanhi[id.(usize)] - ((x * (s1 + s2) - atanlo[id.(usize)]) - x)
    return if sign { -z } else { z }
}
