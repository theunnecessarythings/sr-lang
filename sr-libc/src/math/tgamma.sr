sinpi :: fn(x_in: f64) f64 {
    x := x_in
    x = x * 0.5
    x = 2.0 * (x - floor(x))
    n := (4.0 * x).(i32)
    n = (n + 1) / 2
    x -= n.(f64) * 0.5
    x *= pi
    if n == 0 { return sin_k.__sin(x, 0.0, 0) }
    if n == 1 { return cos_k.__cos(x, 0.0) }
    if n == 2 { return sin_k.__sin(-x, 0.0, 0) }
    return -cos_k.__cos(x, 0.0)
}

S :: fn(x: f64) f64 {
    num: f64 = 0.0
    den: f64 = 0.0
    if x < 8.0 {
        i: i32 = 12
        while i >= 0 {
            num = num * x + Snum[i.(usize)]
            den = den * x + Sden[i.(usize)]
            i -= 1
        }
    } else {
        i: i32 = 0
        while i <= 12 {
            num = num / x + Snum[i.(usize)]
            den = den / x + Sden[i.(usize)]
            i += 1
        }
    }
    return num / den
}

tgamma :: proc(x: f64) f64 {
    u := x.^u64
    absx: f64
    y: f64
    dy: f64
    z: f64
    r: f64
    ix := ((u >> 32) & 0x7fffffff).(u32)
    sign := (u >> 63).(u32)

    if ix >= 0x7ff00000 { return x + (1.0/0.0) }
    if ix < (0x3ff - 54) << 20 { return 1.0 / x }

    if x == floor(x) {
        if sign != 0 { return 0.0 / 0.0 }
        if x <= 23.0 {
            return fact[(x.(i32) - 1).(usize)]
        }
    }

    if ix >= 0x40670000 {
        if sign != 0 {
            _ = (0x1p-126 / x)
            if floor(x) * 0.5 == floor(x * 0.5) { return 0.0 }
            return -0.0
        }
        x = x * 0x1p1023
        return x
    }

    absx = if sign != 0 { -x } else { x }

    y = absx + gmhalf
    if absx > gmhalf {
        dy = y - absx
        dy -= gmhalf
    } else {
        dy = y - gmhalf
        dy -= absx
    }

    z = absx - 0.5
    r = S(absx) * exp(-y)
    if x < 0.0 {
        r = -pi / (sinpi(absx) * absx * r)
        dy = -dy
        z = -z
    }
    r += dy * (gmhalf + 0.5) * r / y
    z = pow(y, 0.5 * z)
    y = r * z * z
    return y
}
