    s = frexpl(s, &lx)
    e := (lx - 1) * n

    if e == 0 or e > 64 or e < -64 {
        s = (s - 7.0710678118654752e-1) / (s + 7.0710678118654752e-1)
        s = (2.9142135623730950 * s - 0.5 + lx.(f128)) * nn.(f128) * LOGE2L
    } else {
        s = LOGE2L * e.(f128)
    }

    if s > MAXLOGL { return huge * huge }
    if s < MINLOGL { return 0x1p-10000 * 0x1p-10000 }
    if s < -MAXLOGL + 2.0 {
        x = 1.0 / x
        sign = -sign
    }

    y: f128
    if (n & 1) != 0 { y = x } else { y = 1.0 }

    ww := x
    n >>= 1
    while n != 0 {
        ww = ww * ww
        if (n & 1) != 0 { y *= ww }
        n >>= 1
    }

    if sign < 0 { y = 1.0 / y }
    return y
}

powl :: proc(x: f128, y: f128) f128 {
    i: i32
    nflg: i32
    iyflg: i32
    yoddint: i32
    e: i32
    z: f128 = 0.0
