polevll :: fn(x: f128, coef: *f128, n: i32) f128 {
    i: i32 = 1
    ans := coef[0]
    while i <= n {
        ans = ans * x + coef[i.(usize)]
        i += 1
    }
    return ans
}

p1evll :: fn(x: f128, coef: *f128, n: i32) f128 {
    i: i32 = 1
    ans := x + coef[0]
    while i < n {
        ans = ans * x + coef[i.(usize)]
        i += 1
    }
    return ans
}

reducl :: fn(x: f128) f128 {
    t := x * NXT
    t = floorl(t)
    return t / NXT
}

powil :: fn(x: f128, nn: i32) f128 {
    if nn == 0 { return 1.0 }

    sign: i32
    n: i32
    if nn < 0 {
        sign = -1
        n = -nn
    } else {
        sign = 1
        n = nn
