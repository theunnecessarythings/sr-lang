package libc

// Derived from musl-1.2.5/src/ipc/semop.c

// TODO: Convert includes to sr-lang imports
// #include <sys/sem.h>
// #include <syscall.h>
// #include <ipc.h>

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

semop :: proc(id: i32, buf: *sembuf, n: usize) i32 {
    return sc.syscall3_ret(nums.SYS_semop.(i64), id.(i64), buf.^usize.(i64), n.(i64)).(i32)
}
