package libc

// Derived from musl-1.2.5/src/ipc/shmctl.c

// TODO: Convert includes to sr-lang imports
// #include <sys/shm.h>
// #include <endian.h>
// #include <syscall.h>
// #include <ipc.h>

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"
ipc :: import "libc/src/ipc/ipc_impl"

shmctl :: proc(id: i32, cmd: i32, buf: *shmid_ds) i32 {
    r := sc.syscall3_ret(nums.SYS_shmctl.(i64), id.(i64), ipc.IPC_CMD(cmd).(i64), buf.^usize.(i64))
    return r.(i32)
}
