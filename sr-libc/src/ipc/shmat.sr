package libc

// Derived from musl-1.2.5/src/ipc/shmat.c

// TODO: Convert includes to sr-lang imports
// #include <sys/shm.h>
// #include <syscall.h>
// #include <ipc.h>

sc :: import "libc/src/syscall/syscall"
nums :: import "libc/include/syscall"

shmat :: proc(id: i32, addr: *const void, flag: i32) *void {
    addr_ptr := if addr == null { 0 } else { addr.^usize }
    r := sc.syscall3_ret(nums.SYS_shmat.(i64), id.(i64), addr_ptr.(i64), flag.(i64))
    return r.(isize).(usize).^*void
}
